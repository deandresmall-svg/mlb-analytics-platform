MLB_DATABASE_URL=sqlite:///data/mlb_analytics.db
MLB_API_BASE_URL=https://statsapi.mlb.com/api/v1
WEATHER_BASE_URL=https://api.open-meteo.com/v1
WEATHER_ARCHIVE_URL=https://archive-api.open-meteo.com/v1/archive
API_TIMEOUT_SECONDS=20
API_MAX_RETRIES=3
CALIBRATION_METHOD=sigmoid
MODEL_DIR=models
MIN_TRAINING_GAMES=300
DEFAULT_BACKFILL_DAYS=365

# The Odds API
ODDS_API_KEY=
ODDS_REGIONS=us,us2
ODDS_BOOKMAKERS=

# Baseball Savant Statcast
STATCAST_BASE_URL=https://baseballsavant.mlb.com/statcast_search/csv
STATCAST_TIMEOUT_SECONDS=90
STATCAST_CHUNK_DAYS=3
STATCAST_DEFAULT_SYNC_DAYS=30
